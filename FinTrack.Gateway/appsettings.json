{
  "Serilog": {
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [{ "Name": "Console" }]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "Match": { "Path": "/api/wallets/{**catch-all}" }
      },
      "notify-route": {
        "ClusterId": "notify-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-1": { "Address": "http://localhost:5001" }
        }
      },
      "wallet-cluster": {
        "Destinations": {
          "wallet-1": { "Address": "http://localhost:5002" }
        }
      },
      "notify-cluster": {
        "Destinations": {
          "notify-1": { "Address": "http://localhost:5003" }
        }
      }
    }
  }
}
